DEBUG=False
SECRET_KEY=your-secret-key-here
ALLOWED_HOSTS=tu-app.onrender.com
CSRF_TRUSTED_ORIGINS=https://tu-app.onrender.com
DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-REGION.pooler.supabase.com:5432/postgres
PYTHON_VERSION=3.13.12
LOG_LEVEL=INFO

# Recordatorios diarios por correo (ver CLAUDE.md, sección "Automatización de correos")
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=correos@lostocayos.com
EMAIL_HOST_PASSWORD=contraseña-de-aplicacion-de-gmail
DEFAULT_FROM_EMAIL=Los Tocayos <correos@lostocayos.com>

# Scheduler del recordatorio diario: True en Render (APScheduler), False en VPS (usa cron nativo)
SCHEDULER_ENABLED=True
